# Database
DB_PASSWORD=sorteagora123

# JWT — Compose exige ≥32 chars (sem default fraco)
JWT_SECRET=change-me-jwt-secret-at-least-32-chars!!
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Encryption — Compose exige ≥32 chars
ENCRYPTION_KEY=change-me-encryption-key-32chars!

# PIX (false = webhook; true = auto-confirma sandbox)
PIX_AUTO_CONFIRM=false
PIX_PROVIDER_MODE=sandbox
PIX_API_BASE_URL=
PIX_ACCESS_TOKEN=
PIX_WEBHOOK_SECRET=

# External Services
