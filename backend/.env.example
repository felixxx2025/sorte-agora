NODE_ENV=development
PORT=3001
API_PREFIX=/api

# Database (Compose local mapeia Postgres em 5434)
DATABASE_URL="postgresql://sorteagora:sorteagora123@localhost:5434/sorte_agora?schema=public"

# Redis (Compose local mapeia Redis em 6380)
REDIS_URL="redis://localhost:6380"

# Frontend URL (links de reset de senha)
FRONTEND_URL="http://localhost:3000"

# PIX: true = credita saldo automaticamente (sandbox local)
# Compose/produção: false + webhook
PIX_AUTO_CONFIRM=true
PIX_PROVIDER_MODE=sandbox
# PIX_PROVIDER_MODE=http + PIX_API_BASE_URL para PSP remoto
PIX_API_BASE_URL=
PIX_ACCESS_TOKEN=
PIX_WEBHOOK_SECRET=
PIX_HTTP_SYNC_PAYOUT=false
DEPOSIT_DAILY_LIMIT=50000
WITHDRAW_DAILY_LIMIT=20000

# JWT (≥32 chars; production/staging exige secrets fortes)
JWT_SECRET="dev-only-jwt-secret-at-least-32-characters"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Encryption (≥32 chars)
ENCRYPTION_KEY="dev-only-encryption-key-32chars!!"

# CORS
CORS_ORIGIN="http://localhost:3000,http://localhost:3010,http://localhost:8080"

# External Services
PIX_API_KEY="your-pix-api-key"
CASINO_PROVIDER_API_KEY="your-casino-provider-key"
CASINO_PROVIDER_MODE=demo
CASINO_PROVIDER_BASE_URL=
CASINO_REQUIRE_API_KEY=false
SPORTS_ODDS_API_KEY="your-sports-odds-key"
SPORTS_ODDS_API_URL=
SPORTS_ODDS_MODE=static

# Email
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="noreply@sorteagora.com"
SMTP_PASSWORD="your-smtp-password"
SMTP_FROM=noreply@sorteagora.com

# SMS
SMS_API_KEY="your-sms-api-key"
SMS_API_SECRET="your-sms-secret"

# Storage (local | minio-volume)
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./uploads
STORAGE_PUBLIC_BASE=http://localhost:3001/uploads
S3_BUCKET="sorte-agora-uploads"
S3_REGION="us-east-1"
S3_ACCESS_KEY="your-access-key"
S3_SECRET_KEY="your-secret-key"
S3_ENDPOINT=

# Monitoring
SENTRY_DSN="your-sentry-dsn"
JAEGER_ENDPOINT="http://localhost:4318/v1/traces"
JAEGER_AGENT_HOST="localhost"
JAEGER_AGENT_PORT="6831"

# Security
RECAPTCHA_SECRET="your-recaptcha-secret"
RATE_LIMIT_REDIS_URL="redis://localhost:6379"

# Features
ENABLE_CASINO=true
ENABLE_SPORTS=true
ENABLE_VIP=true
ENABLE_AFFILIATES=true
ENABLE_LGPD=true
ENABLE_CRASH=true
ENABLE_CHAT=true
CASINO_PROVIDER_MODE=demo
CASINO_PROVIDER_BASE_URL=
FRONTEND_URL=http://localhost:3000
SPORTS_SETTLEMENT_CRON=true
SPORTS_AUTO_SETTLE_LOST=false
SPORTS_EVENT_TTL_HOURS=3
